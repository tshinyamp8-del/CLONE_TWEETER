                </div>
                
                <nav style="display: flex; flex-direction: column; gap: 8px; margin-top: 10px;">
                    <button onclick="showPage('home')" style="display: flex; align-items: center; gap: 20px; font-size: 20px; color: #fff; background: none; border: none; width: 100%; text-align: left; padding: 12px 20px; border-radius: 9999px; cursor: pointer; font-family: sans-serif;">
