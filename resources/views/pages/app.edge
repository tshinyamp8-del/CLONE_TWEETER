                    </button>

                    <button onclick="showPage('profile')" style="display: flex; align-items: center; gap: 20px; font-size: 20px; color: #fff; background: none; border: none; width: 100%; text-align: left; padding: 12px 20px; border-radius: 9999px; cursor: pointer; font-family: sans-serif;">
                        <i class="fa-solid fa-user"></i> <span>Profil</span>
                    </button>

                    <button onclick="showPage('explorer')" style="display: flex; align-items: center; gap: 20px; font-size: 20px; color: #fff; background: none; border: none; width: 100%; text-align: left; padding: 12px 20px; border-radius: 9999px; cursor: pointer; font-family: sans-serif;">
                        <i class="fa-solid fa-magnifying-glass"></i> <span>Explorer</span>
                    </button>

                    <button onclick="showPage('notifications')" style="display: flex; align-items: center; gap: 20px; font-size: 20px; color: #fff; background: none; border: none; width: 100%; text-align: left; padding: 12px 20px; border-radius: 9999px; cursor: pointer; font-family: sans-serif;">
                        <i class="fa-solid fa-bell"></i> <span>Notifications</span>
                    </button>

                    <button onclick="showPage('messages')" style="display: flex; align-items: center; gap: 20px; font-size: 20px; color: #fff; background: none; border: none; width: 100%; text-align: left; padding: 12px 20px; border-radius: 9999px; cursor: pointer; font-family: sans-serif;">
                        <i class="fa-solid fa-envelope"></i> <span>Messages</span>
                    </button>

                    <button onclick="showPage('bookmarks')" style="display: flex; align-items: center; gap: 20px; font-size: 20px; color: #fff; background: none; border: none; width: 100%; text-align: left; padding: 12px 20px; border-radius: 9999px; cursor: pointer; font-family: sans-serif;">
                        <i class="fa-solid fa-bookmark"></i> <span>Signets</span>
                    </button>

                    <div onclick="showSection('settingsSection')" style="display: flex; align-items: center; gap: 20px; font-size: 20px; color: #fff; padding: 12px 20px; border-radius: 9999px; cursor: pointer; font-family: sans-serif;">
                        <i class="fa-solid fa-gear"></i> <span>Paramètres</span>
                    </div>

                    <div onclick="logout()" style="display: flex; align-items: center; gap: 20px; font-size: 20px; color: #fff; padding: 12px 20px; border-radius: 9999px; cursor: pointer; font-family: sans-serif;">
    <i class="fa-solid fa-right-from-bracket"></i> <span>Se déconnecter</span>
</div>
                </nav>

                <button onclick="document.getElementById('tweetInput').focus()" style="background-color: #1d9bf0; color: white; border: none; font-weight: bold; font-size: 17px; width: 100%; padding: 14px; border-radius: 9999px; margin-top: 15px; cursor: pointer;">
                    Poster
                </button>
            </div>

            {{-- Bloc Profil Utilisateur en bas de la sidebar --}}
            <div style="display: flex; align-items: center; gap: 12px; padding: 10px; margin-bottom: 15px;">
                <div style="background-color: #555; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                    {{ auth.user.username.slice(0, 2).toUpperCase() }}
                </div>
                <div>
                    <div style="font-weight: bold; font-size: 14px;">{{ auth.user.username }}</div>
                    <div style="color: #71767b; font-size: 13px;">@ {{ auth.user.username.toLowerCase().replace(' ', '') }}</div>
                </div>
            </div>
        </aside>

        {{-- 2. COLONNE CENTRALE : FLUX DE CONTENU --}}
        <main style="border-right: 1px solid #2f3336; min-height: 100vh;">
            {{-- PAGE ACCUEIL --}}
            <div id="page-home" class="page-content">
                <div style="padding: 15px; border-bottom: 1px solid #2f3336; position: sticky; top: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(4px); z-index: 10;">
                    <h3 style="margin: 0; font-size: 20px; font-family: sans-serif;">Accueil</h3>
                </div>

                {{-- Zone d'écriture de tweet --}}
                <div style="display: flex; gap: 12px; padding: 15px; border-bottom: 1px solid #2f3336;">
                    <div style="background-color: #555; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                        {{ auth.user.username.slice(0, 2).toUpperCase() }}
                    </div>
                    <div style="flex: 1;">
    <textarea id="tweetInput" placeholder="Quoi de neuf ?" style="width: 100%; background: none; border: none; color: white; font-size: 1.2rem; resize: none; outline: none; min-height: 60px; font-family: sans-serif;"></textarea>
    
    <div id="mediaPreview" class="hidden" style="margin-top: 10px; max-height: 300px; overflow: hidden; border-radius: 15px; position: relative; background: #15181c;">
        <div id="previewContent"></div>
        
        <button type="button" onclick="clearMedia()" style="position: absolute; top: 10px; right: 10px; background: rgba(0,0,0,0.7); color: white; border: none; border-radius: 50%; width: 30px; height: 30px; cursor: pointer; font-weight: bold; z-index: 10;">
            ✕
        </button>
    </div>
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
        <div style="display: flex; gap: 15px; color: #1d9bf0; font-size: 1.2rem;">
            <label for="postImage" style="cursor: pointer;"><i class="fa-regular fa-image"></i></label>
            <input type="file" id="postImage" accept="image/*" style="display: none;" onchange="handleMediaSelect(this, 'image')">
            
            <label for="postVideo" style="cursor: pointer;"><i class="fa-regular fa-file-video"></i></label>
            <input type="file" id="postVideo" accept="video/*" style="display: none;" onchange="handleMediaSelect(this, 'video')">
        </div>
        <button type="button" onclick="postTweet()" style="background: #1d9bf0; color: white; border: none; padding: 8px 18px; border-radius: 20px; font-weight: bold; cursor: pointer; font-size: 15px;">
            Poster
        </button>
    </div>
</div>
                </div>
                
                {{-- Conteneur de Tweets dynamiques --}}
                <div id="tweetsContainer"></div>
            </div>

            {{-- Écris tes autres sous-pages cachées ici (profile, explorer, etc.) en gardant leur style="display: none;" au départ --}}

            <div id="page-profile" class="page-content hidden">
    <div class="top-nav" style="display: flex; align-items: center; gap: 20px; padding: 10px 15px;">
        <i class="fa-solid fa-arrow-left" onclick="window.showPage('home')" style="cursor: pointer;"></i>
        <div>
            <h3 style="margin: 0; font-size: 18px; color: #fff;"><span id="profNameTitle">{{ auth.user.username }}</span></h3>
        </div>
    </div>

    <div class="profile-header" style="position: relative;">
        <div class="profile-banner" style="width: 100%; height: 200px; overflow: hidden; background: #333;">
