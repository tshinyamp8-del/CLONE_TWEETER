        <aside style="border-right: 1px solid #2f3336; padding: 10px 20px; display: flex; flex-direction: column; justify-content: space-between; height: 100vh; position: sticky; top: 0;">
            <div class="nav-links">
                <div style="font-size: 30px; padding: 10px; color: #fff; width: fit-content; cursor: pointer;">
