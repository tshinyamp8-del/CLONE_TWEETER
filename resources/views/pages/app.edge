                 style="width: 130px; height: 130px; border-radius: 50%; border: 4px solid #000; background-color: #15181c; object-fit: cover; display: block; flex-shrink: 0;">
            
            <div style="margin-bottom: 12px;">
                <button class="edit-profile-btn-outline" onclick="window.openEditModal()">Éditer le profil</button>
            </div>
        </div>
    </div>

    <div class="profile-info" style="padding: 15px; margin-top: 10px;">
        <h2 style="color: #fff; margin: 0; font-size: 22px; font-weight: bold;"><span id="profNameDisplay">{{ auth.user.username }}</span></h2>
        
        <p class="handle" style="color: #71767b; margin: 2px 0 12px 0;">@<span id="profHandleDisplay">{{ auth.user.username.toLowerCase().replace(/\s/g, '') }}</span></p>
        
        <p class="bio" style="color: #fff; margin: 12px 0; font-size: 15px;"><span id="profBioDisplay">{{ auth.user.bio || 'Pas encore de biographie.' }}</span></p>

        <p style="color: #71767b; font-size: 14px;">
            <span id="followersCount" style="color: #fff; font-weight: bold;">0</span> abonnés •
            <span id="followingCount" style="color: #fff; font-weight: bold;">0</span> abonnements
        </p>
    </div>
</div>
