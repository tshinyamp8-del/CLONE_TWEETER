    {{-- INTERFACE PRINCIPALE EN 3 COLONNES STRUCTURÉES --}}
    <div id="appContainer" style="display: grid; grid-template-columns: 275px 600px 350px; max-width: 1225px; margin: 0 auto; min-height: 100vh;">

